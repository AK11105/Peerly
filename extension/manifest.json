{
  "manifest_version": 3,
  "name": "Loom by Peerly",
  "version": "1.0.0",
  "description": "Prefix any URL with loom. to instantly create a Peerly weave from that page.",
  "permissions": ["webNavigation", "tabs"],
  "host_permissions": ["*://loom.*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": { "32": "icon32.png", "48": "icon32.png", "128": "icon32.png" },
  "action": {
    "default_title": "Loom by Peerly",
    "default_icon": "icon32.png"
  }
}
